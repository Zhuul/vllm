diff --git a/csrc/cache_kernels.cu b/csrc/cache_kernels.cu
index c59da4379d..a7ad941a5f 100644
--- a/csrc/cache_kernels.cu
+++ b/csrc/cache_kernels.cu
@@ -101,29 +101,82 @@ void swap_blocks_batch(const torch::Tensor& src_ptrs,
   // driver call, amortizing per-copy submission overhead.
   // int64_t and CUdeviceptr/size_t are both 8 bytes on 64-bit platforms,
   // so we reinterpret_cast the tensor data directly to avoid copies.
+  // Compatibility note: CUDA headers observed in our CUDA 13.2 dev image
+  // expose an 8-argument cuMemcpyBatchAsync signature, while newer toolkits
+  // may expose a variant that also reports fail_idx. Use overload resolution
+  // on the function pointer type and fall back to per-copy submission if an
+  // unexpected signature appears in a future toolkit.
   static_assert(sizeof(CUdeviceptr) == sizeof(int64_t));
   static_assert(sizeof(size_t) == sizeof(int64_t));
 #if !defined(USE_ROCM) && defined(CUDA_VERSION) && CUDA_VERSION >= 12080
+  auto fallback_memcpy_async = [&]() {
+    for (int64_t i = 0; i < n; i++) {
+      cudaMemcpyAsync(reinterpret_cast<void*>(dst_data[i]),
+                      reinterpret_cast<void*>(src_data[i]),
+                      static_cast<size_t>(size_data[i]), cudaMemcpyDefault,
+                      stream);
+    }
+  };
+
+  using CuMemcpyBatchAsyncV1 = CUresult(CUDAAPI *)(
+      CUdeviceptr*, CUdeviceptr*, size_t*, size_t, CUmemcpyAttributes*,
+      size_t*, size_t, CUstream);
+  using CuMemcpyBatchAsyncV2 = CUresult(CUDAAPI *)(
+      CUdeviceptr*, CUdeviceptr*, size_t*, size_t, CUmemcpyAttributes*,
+      size_t*, size_t, size_t*, CUstream);
+  struct CuMemcpyBatchAsyncCompat {
+    static CUresult call(CuMemcpyBatchAsyncV1 fn, CUdeviceptr* dsts,
+                         CUdeviceptr* srcs, size_t* sizes, size_t count,
+                         CUmemcpyAttributes* attrs, size_t* attrs_idx,
+                         size_t num_attrs, size_t* fail_idx,
+                         CUstream stream) {
+      if (fail_idx != nullptr) {
+        *fail_idx = 0;
+      }
+      return fn(dsts, srcs, sizes, count, attrs, attrs_idx, num_attrs,
+                stream);
+    }
+
+    static CUresult call(CuMemcpyBatchAsyncV2 fn, CUdeviceptr* dsts,
+                         CUdeviceptr* srcs, size_t* sizes, size_t count,
+                         CUmemcpyAttributes* attrs, size_t* attrs_idx,
+                         size_t num_attrs, size_t* fail_idx,
+                         CUstream stream) {
+      return fn(dsts, srcs, sizes, count, attrs, attrs_idx, num_attrs,
+                fail_idx, stream);
+    }
+
+    static CUresult call(... ) {
+      return CUDA_ERROR_NOT_SUPPORTED;
+    }
+  };
+
+  constexpr auto cuMemcpyBatchAsyncPtr = &cuMemcpyBatchAsync;
   CUmemcpyAttributes attr = {};
   attr.srcAccessOrder = CU_MEMCPY_SRC_ACCESS_ORDER_STREAM;
   size_t attrs_idx = 0;
   size_t fail_idx = 0;
-  CUresult result = cuMemcpyBatchAsync(
+  CUresult result = CuMemcpyBatchAsyncCompat::call(
+      cuMemcpyBatchAsyncPtr,
       reinterpret_cast<CUdeviceptr*>(const_cast<int64_t*>(dst_data)),
       reinterpret_cast<CUdeviceptr*>(const_cast<int64_t*>(src_data)),
       reinterpret_cast<size_t*>(const_cast<int64_t*>(size_data)),
       static_cast<size_t>(n), &attr, &attrs_idx, 1, &fail_idx,
       static_cast<CUstream>(stream));
-  TORCH_CHECK(result == CUDA_SUCCESS, "cuMemcpyBatchAsync failed at index ",
-              fail_idx, " with error ", result);
+  if (result == CUDA_ERROR_NOT_SUPPORTED) {
+    fallback_memcpy_async();
+  } else {
+    TORCH_CHECK(result == CUDA_SUCCESS, "cuMemcpyBatchAsync failed at index ",
+                fail_idx, " with error ", result);
+  }
 #else
   // Fallback for CUDA < 12.8 and ROCm: individual async copies.
   // cudaMemcpyDefault lets the driver infer direction from pointer types.
   for (int64_t i = 0; i < n; i++) {
     cudaMemcpyAsync(reinterpret_cast<void*>(dst_data[i]),
                     reinterpret_cast<void*>(src_data[i]),
                     static_cast<size_t>(size_data[i]), cudaMemcpyDefault,
                     stream);
   }
 #endif
 }

